// ============================================================================
// trap_test.mem — 上板可见的中断测试程序
// ============================================================================
// 人眼最小分辨 ~50ms。100MHz 时钟下, 5,000,000 周期 ≈ 50ms。
//
// 按 btn_run 后你会看到:
//   Phase 1 (0.5s): LED = 00001111  (低4位亮)
//   Phase 2 (0.5s): LED = 11110000  (高4位亮)
//   Phase 3 (持续): LED 缓慢闪烁   (mtime 高字节 → 约6Hz)
//   Phase 4 (约2s后): LED = 11111111 (全亮! 中断触发)
//   Phase 5 (0.5s后): LED 恢复闪烁  (MRET 返回)
// ============================================================================

// ══ Phase 1: LED = 0x0F, 延时约 0.5s ══
100002B7  // 00: lui  x5, 0x10000        — x5  = 0x10000000 (LED)
00F00313  // 04: addi x6, x0, 0x0F       — x6  = 0x0F
0062A023  // 08: sw   x6, 0(x5)          — LED = 0x0F (低4位亮)
// 嵌套延时: 2048 × 2500 × 2周期 × 10ns ≈ 102ms × 5 ≈ 510ms
00800E37  // 0C: lui  x28, 0x008         — 外循环 2048 次
05000E93  // 10: addi x29, x0, 80        — 内循环初值
FFFE8E93  // 14: addi x29, x29, -1       — DELAY1: 内循环
000E9863  // 18: bne  x29, x0, -16       — 跳回 DELAY1
FFFE0E13  // 1C: addi x28, x28, -1       — 外循环递减
000E1663  // 20: bne  x28, x0, -20       — 跳回外层
// 再跑一轮
00800E37  // 24: lui  x28, 0x008
05000E93  // 28: addi x29, x0, 80
FFFE8E93  // 2C: addi x29, x29, -1
000E9863  // 30: bne  x29, x0, -16
FFFE0E13  // 34: addi x28, x28, -1
000E1663  // 38: bne  x28, x0, -20

// ══ Phase 2: LED = 0xF0, 延时约 0.5s ══
0F000313  // 3C: addi x6, x0, 0xF0       — x6  = 0xF0
0062A023  // 40: sw   x6, 0(x5)          — LED = 0xF0 (高4位亮)
00800E37  // 44: lui  x28, 0x008
05000E93  // 48: addi x29, x0, 80
FFFE8E93  // 4C: addi x29, x29, -1
000E9863  // 50: bne  x29, x0, -16
FFFE0E13  // 54: addi x28, x28, -1
000E1663  // 58: bne  x28, x0, -20
00800E37  // 5C: lui  x28, 0x008
05000E93  // 60: addi x29, x0, 80
FFFE8E93  // 64: addi x29, x29, -1
000E9863  // 68: bne  x29, x0, -16
FFFE0E13  // 6C: addi x28, x28, -1
000E1663  // 70: bne  x28, x0, -20

// ══ Phase 3: CSR 设置 (中断使能) ══
10000313  // 74: addi x6, x0, 0x100      — handler addr = 0x100
30500393  // 78: addi x7, x0, 0x305      — CSR_MTVEC
30731073  // 7C: csrrw x0, x7, x6        — mtvec = 0x100
30400313  // 80: addi x6, x0, 0x304      — CSR_MIE
08000393  // 84: addi x7, x0, 0x80       — MTIE bit7
30731073  // 88: csrrw x0, x7, x6        — mie = 0x80
30000313  // 8C: addi x6, x0, 0x300      — CSR_MSTATUS
00800393  // 90: addi x7, x0, 8          — MIE bit3
30731073  // 94: csrrw x0, x7, x6        — mstatus = 8 (开中断!)

// ══ Phase 4: 设置影子初值 + mtimecmp ══
0A100093  // 98: addi x1, x0, 0xA1       — ra = 0xA1
0B500293  // 9C: addi x5, x0, 0xB5       — t0 = 0xB5
0C600313  // A0: addi x6, x0, 0xC6       — t1 = 0xC6
0D700393  // A4: addi x7, x0, 0xD7       — t2 = 0xD7

// 读取当前 mtime, 加 ~5M (0x4C4B40 ≈ 5,000,000) ≈ 50ms
// mtime 在 0x10000100, 先读, 加偏移, 写回 mtimecmp
10000EB7  // A8: lui  x28, 0x10000
100E0E13  // AC: addi x28, x28, 0x100    — x28 = 0x10000100 (mtime)
000E2F83  // B0: lw   x31, 0(x28)        — x31 = mtime 当前值
104E0E13  // B4: addi x28, x28, 4        — x28 = 0x10000104 (mtimecmp)
04C00EB7  // B8: lui  x29, 0x04C         — x29 = 0x04C000
4B4E8E93  // BC: addi x29, x29, 0x4B4    — x29 = 0x04C4B4 ≈ 5M
01DE8FB3  // C0: add  x31, x29, x31      — x31 = mtime + 5M
01FE2023  // C4: sw   x31, 0(x28)        — mtimecmp = mtime + 5M (~50ms后中断!)

// ══ Phase 5: 主循环 — 读 mtime 显示在 LED 上 ══
// LED 显示 mtime 的高字节 (mtime[31:24]), 约 6Hz 变化, 人眼可见
10000EB7  // C8: lui  x28, 0x10000       — x28 = 0x10000000 (LED)
100E8E13  // CC: addi x28, x28, 0x100    — x28 = 0x10000100 (mtime...)
//            wait, this overwrites x28 with mtime addr
//            需要两个不同的基址寄存器
// 重新算偏移, 从 0xCC 开始:
// 实际上应该用不同寄存器。让我简化:
// x28 = LED addr, x29 = mtime addr, x30 = mtimecmp addr
00000EB7  // C8: lui  x28, 0x000...      — 这个先跳过, 我重新规划
//
// 其实在 0xC8 处:
// x28 已被设为 0x10000104, 给我重新用:
// x5 已经是 0x10000000 (Phase 1设置的), 直接用!
// x28 = 0x10000104, 那么:
// x29 = 0x10000100 (mtime addr) = x28 - 4
FFCE8E93  // C8: addi x29, x28, -4       — x29 = 0x10000100 (mtime)
000EAF83  // CC: lw   x31, 0(x29)        — LOOP: x31 = mtime
018FDF93  // D0: srli x31, x31, 24       — x31 = mtime[31:24] (~6Hz)
01F2A023  // D4: sw   x31, 0(x5)         — LED = mtime 高字节
000EAF83  // D8: lw   x31, 0(x29)        — 再读一次 (延时)
000EAF83  // DC: lw   x31, 0(x29)        — 再读一次 (延时)
000EAF83  // E0: lw   x31, 0(x29)        — 再读一次 (延时)
FE5FF06F  // E4: jal  x0, -28            — 跳回 LOOP (0xCC)

// Padding to 0x100
00000013  // E8: NOP
00000013  // EC: NOP
00000013  // F0: NOP
00000013  // F4: NOP
00000013  // F8: NOP
00000013  // FC: NOP

// ════════════════════════════════════════════════════════════
// ISR Handler (PC 0x100, imem[64])
// ════════════════════════════════════════════════════════════

// 全亮 LED = 0xFF
0FF00313  // 100: addi x6, x0, 0xFF       — x6 = 0xFF
0062A023  // 104: sw   x6, 0(x5)          — LED = 0xFF (全部亮!)
00602023  // 108: sw   x6, 0(x0)          — dmem[0] = 0xFF (标记)

// 延时约 0.5s, 让用户看到全亮
00800E37  // 10C: lui  x28, 0x008
05000E93  // 110: addi x29, x0, 80
FFFE8E93  // 114: addi x29, x29, -1
000E9863  // 118: bne  x29, x0, -16
FFFE0E13  // 11C: addi x28, x28, -1
000E1663  // 120: bne  x28, x0, -20
00800E37  // 124: lui  x28, 0x008
05000E93  // 128: addi x29, x0, 80
FFFE8E93  // 12C: addi x29, x29, -1
000E9863  // 130: bne  x29, x0, -16
FFFE0E13  // 134: addi x28, x28, -1
000E1663  // 138: bne  x28, x0, -20

// 保存影子寄存器到 dmem (验证捕获)
// x5 = 0x10000000 (LED addr, 仍是), dmem写入
00102223  // 13C: sw   x1, 4(x0)          — dmem[1] = ra (应=0xA1)
00502423  // 140: sw   x5, 8(x0)          — dmem[2] = t0 (应=0xB5)
00602623  // 144: sw   x6, 12(x0)         — dmem[3] = t1 (应=0xC6)
00702823  // 148: sw   x7, 16(x0)         — dmem[4] = t2 (应=0xD7)

// 破坏寄存器
0DE00093  // 14C: addi x1, x0, 0xDE       — ra = 0xDE
0AD00293  // 150: addi x5, x0, 0xAD       — t0 = 0xAD
0BE00313  // 154: addi x6, x0, 0xBE       — t1 = 0xBE
0EF00393  // 158: addi x7, x0, 0xEF       — t2 = 0xEF

// 重置 mtimecmp (大值, 不再触发)
10000EB7  // 15C: lui  x28, 0x10000
104E0E13  // 160: addi x28, x28, 0x104    — x28 = 0x10000104
000E2F83  // 164: lw   x31, 0(x28-4)      — x31 = mtime (0x10000100)
// 不对, 需要先读mtime再写mtimecmp
// x28 = 0x10000104, mtime在0x10000100 = x28-4
FFCE8E93  // 164: addi x29, x28, -4       — x29 = 0x10000100
000EAF83  // 168: lw   x31, 0(x29)        — x31 = mtime
01F00FB7  // 16C: lui  x31, 0x01F00       — 不对, lui覆盖了x31
//
// 算了, 简化: ISR 不重置 mtimecmp, 直接 MRET
// ===== 直接 MRET (PC 0x164) =====
30200073  // 164: mret
