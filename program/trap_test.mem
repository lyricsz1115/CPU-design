// ============================================================================
// trap_test.mem — RISC-V 中断系统综合测试程序
// ============================================================================
// 测试项:
//   1. CSRRW CSR 读写 (mtvec, mie, mstatus)
//   2. 定时器中断触发 (mtimecmp=80)
//   3. 影子寄存器保存验证 (dmem[1..5])
//   4. MRET 影子寄存器恢复验证 (regfile regs[1,5,6,7])
//   5. 非影子寄存器(x8)不被恢复验证
//
// 预期结果 (300 周期后):
//   dmem[0] = 0xFF    (ISR 标记)
//   dmem[1] = 0xA1    (影子 x1/ra 保存值)
//   dmem[2] = 0xB5    (影子 x5/t0 保存值)
//   dmem[3] = 0xC6    (影子 x6/t1 保存值)
//   dmem[4] = 0xD7    (影子 x7/t2 保存值)
//   dmem[5] = 0xE8    (x8/s0 未被影子修改 — 对照)
//   regs[1] = 0xA1    (MRET 后 x1 被影子恢复)
//   regs[5] = 0xB5    (MRET 后 x5 被影子恢复)
//   regs[6] = 0xC6    (MRET 后 x6 被影子恢复)
//   regs[7] = 0xD7    (MRET 后 x7 被影子恢复)
//   regs[8] = 0xFE    (MRET 后 x8 保持 ISR 修改值 — 不被恢复!)
//
// 程序布局:
//   Main: PC 0x00-0x58
//   Padding: 0x5C-0xFC (NOP)
//   ISR Handler: PC 0x100-0x148
// ============================================================================

// ── Main: CSR 设置 (PC 0x00) ──
10000293  // 00: addi x5, x0, 0x100       -- x5 = 0x100 (handler addr)
30500313  // 04: addi x6, x0, 0x305       -- x6 = CSR_MTVEC
30529073  // 08: csrrw x0, x6, x5         -- mtvec = 0x100
30400293  // 0C: addi x5, x0, 0x304       -- x5 = CSR_MIE
08000313  // 10: addi x6, x0, 0x80        -- x6 = 0x80 (MTIE bit7)
30433073  // 14: csrrw x0, x5, x6         -- mie = 0x80
30000293  // 18: addi x5, x0, 0x300       -- x5 = CSR_MSTATUS
00800313  // 1C: addi x6, x0, 8           -- x6 = 8 (MIE bit3)
30033073  // 20: csrrw x0, x5, x6         -- mstatus = 0x8 (开全局中断)

// ── Main: 设置影子寄存器测试初值 (PC 0x24) ──
0A100093  // 24: addi x1, x0, 0xA1        -- ra = 0xA1 (会被影子捕获)
0B500293  // 28: addi x5, x0, 0xB5        -- t0 = 0xB5 (会被影子捕获)
0C600313  // 2C: addi x6, x0, 0xC6        -- t1 = 0xC6 (会被影子捕获)
0D700393  // 30: addi x7, x0, 0xD7        -- t2 = 0xD7 (会被影子捕获)
0E800413  // 34: addi x8, x0, 0xE8        -- s0 = 0xE8 (不会被影子捕获, 对照!)

// ── Main: 设置 mtimecmp = 80 (PC 0x38) ──
10000EB7  // 38: lui  x28, 0x10000        -- x28 = 0x10000000
104E0E13  // 3C: addi x28, x28, 0x104     -- x28 = 0x10000104 (mtimecmp)
05000E93  // 40: addi x29, x0, 80         -- x29 = 80
01DE2023  // 44: sw   x29, 0(x28)         -- mtimecmp = 80

// ── Main: 主循环 (PC 0x48) ──
00000F93  // 48: addi x31, x0, 0          -- x31 = 0 (循环计数器)
10000F37  // 4C: lui  x30, 0x10000        -- x30 = 0x10000000 (LED 地址)
001F8F93  // 50: addi x31, x31, 1         -- LOOP: x31++ (约 80 次后中断触发)
01FF2023  // 54: sw   x31, 0(x30)         -- LED = x31 (上板可见)
FF5FF06F  // 58: jal  x0, -12             -- 跳回 LOOP (0x50)

// ── Padding: NOP 填充到 0x100 (PC 0x5C .. 0xFC) ──
00000013  // 5C
00000013  // 60
00000013  // 64
00000013  // 68
00000013  // 6C
00000013  // 70
00000013  // 74
00000013  // 78
00000013  // 7C
00000013  // 80
00000013  // 84
00000013  // 88
00000013  // 8C
00000013  // 90
00000013  // 94
00000013  // 98
00000013  // 9C
00000013  // A0
00000013  // A4
00000013  // A8
00000013  // AC
00000013  // B0
00000013  // B4
00000013  // B8
00000013  // BC
00000013  // C0
00000013  // C4
00000013  // C8
00000013  // CC
00000013  // D0
00000013  // D4
00000013  // D8
00000013  // DC
00000013  // E0
00000013  // E4
00000013  // E8
00000013  // EC
00000013  // F0
00000013  // F4
00000013  // F8
00000013  // FC

// ════════════════════════════════════════════════════════════
// ISR Handler (PC 0x100, imem[64])
// ════════════════════════════════════════════════════════════

// ── 写 ISR 标记 (PC 0x100) ──
0FF00E93  // 100: addi x29, x0, 0xFF       -- x29 = 0xFF
10000EB7  // 104: lui  x28, 0x10000        -- x28 = 0x10000000
01DEA023  // 108: sw   x29, 0(x28)         -- LED = 0xFF (上板可见中断标记)
01D02023  // 10C: sw   x29, 0(x0)          -- dmem[0] = 0xFF

// ── 保存当前寄存器值到 dmem (验证影子捕获) (PC 0x110) ──
// 中断触发时硬件影子已自动捕获 x1/x2/x5/x6/x7 的旧值
// ISR 中读取的这些寄存器值 = 影子捕获的值
00102223  // 110: sw   x1, 4(x0)           -- dmem[1] = ra (期望 0xA1)
00502423  // 114: sw   x5, 8(x0)           -- dmem[2] = t0 (期望 0xB5)
00602623  // 118: sw   x6, 12(x0)          -- dmem[3] = t1 (期望 0xC6)
00702823  // 11C: sw   x7, 16(x0)          -- dmem[4] = t2 (期望 0xD7)
00802A23  // 120: sw   x8, 20(x0)          -- dmem[5] = s0 (期望 0xE8, 对照!)

// ── 破坏寄存器值 (PC 0x124) ──
// 影子寄存器 (x1/x5/x6/x7): 会被 MRET 恢复
// 非影子寄存器 (x8): MRET 后保持修改值
0DE00093  // 124: addi x1, x0, 0xDE        -- ra = 0xDE (将被影子恢复)
0AD00293  // 128: addi x5, x0, 0xAD        -- t0 = 0xAD (将被影子恢复)
0BE00313  // 12C: addi x6, x0, 0xBE        -- t1 = 0xBE (将被影子恢复)
0EF00393  // 130: addi x7, x0, 0xEF        -- t2 = 0xEF (将被影子恢复)
0FE00413  // 134: addi x8, x0, 0xFE        -- s0 = 0xFE (不会被恢复, 保留!)

// ── 重置 mtimecmp (PC 0x138) ──
10000EB7  // 138: lui  x28, 0x10000        -- x28 = 0x10000000
104E0E13  // 13C: addi x28, x28, 0x104     -- x28 = 0x10000104
00001EB7  // 140: lui  x29, 0x1            -- x29 = 0x1000 (大值, 不再触发)
01DE2023  // 144: sw   x29, 0(x28)         -- mtimecmp = 4096

// ── 陷阱返回 (PC 0x148) ──
// MRET → shadow_restore → 批量恢复 x1/x5/x6/x7
// → mepc 跳转回主循环继续执行
// → x31 持续递增, LED 显示计数器值
30200073  // 148: mret
